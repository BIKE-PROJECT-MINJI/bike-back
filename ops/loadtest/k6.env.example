# k6 공통 대상
BASE_URL=http://localhost:8080

# 실행 모드: smoke | baseline | stress
SCENARIO=smoke
TEST_ID=bike-smoke-local
SUMMARY_DIR=ops/loadtest/results

# 활성 페르소나: home,preRide,inRide,write,health
PERSONAS=home,preRide,inRide,write,health

# smoke 기본값
SMOKE_MAX_DURATION=1m
SMOKE_HOME_VUS=1
SMOKE_HOME_ITERATIONS=2
SMOKE_PRERIDE_VUS=1
SMOKE_PRERIDE_ITERATIONS=2
SMOKE_INRIDE_VUS=1
SMOKE_INRIDE_ITERATIONS=2
SMOKE_WRITE_VUS=1
SMOKE_WRITE_ITERATIONS=1
SMOKE_HEALTH_VUS=1
SMOKE_HEALTH_ITERATIONS=2

# baseline/stress 총 VU와 페르소나 비중
BASELINE_TOTAL_VUS=10
BASELINE_RAMP_UP=2m
BASELINE_HOLD=5m
BASELINE_RAMP_DOWN=2m

STRESS_TOTAL_VUS=25
STRESS_RAMP_UP=1m
STRESS_HOLD=3m
STRESS_RAMP_DOWN=1m

# 페르소나 비중(%). 합이 100이 되게 맞추는 것을 권장
HOME_WEIGHT_PERCENT=35
PRERIDE_WEIGHT_PERCENT=30
INRIDE_WEIGHT_PERCENT=20
WRITE_WEIGHT_PERCENT=10
HEALTH_WEIGHT_PERCENT=5

# 품질 게이트
P95_MS=800
ROUTE_READ_P95_MS=1000
WEATHER_P95_MS=1200
RIDE_POLICY_P95_MS=1200
LOCATION_P95_MS=500
WRITE_P95_MS=1500
ERROR_RATE_MAX=0.01

# 코스/정책 테스트용 선택값
# 비워두면 setup()이 featured/list 응답에서 첫 courseId를 자동 탐색합니다.
COURSE_ID=
RIDE_PHASE=PRE_START
RIDE_LAT=37.5665
RIDE_LON=126.9780
RIDE_ACCURACY_M=15

# 날씨 테스트용 좌표
WEATHER_LAT=37.5665
WEATHER_LON=126.9780

# 인증이 필요한 엔드포인트를 때릴 때만 사용
AUTH_BEARER_TOKEN=

# 쓰기 시나리오용 좌표
WRITE_START_LAT=37.5665
WRITE_START_LON=126.9780
WRITE_END_LAT=37.5670
WRITE_END_LON=126.9785

# iteration 사이 간격(초)
SLEEP_SECONDS=1
