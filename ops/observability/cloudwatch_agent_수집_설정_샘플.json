{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
        {
          "file_path": "/var/log/nginx/bike_access.log",
          "log_group_name": "/bike-back/nginx/access",
          "log_stream_name": "{instance_id}",
          "timestamp_format": "%Y-%m-%dT%H:%M:%S%z"
        },
        {
          "file_path": "/opt/bike-back/shared/logs/app.log",
          "log_group_name": "/bike-back/app",
          "log_stream_name": "{instance_id}",
          "timestamp_format": "%Y-%m-%dT%H:%M:%S.%f%z"
        }
        ]
      }
    }
  }
}
